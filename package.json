{
  "name": "claude-code-monitor",
  "version": "0.1.0",
  "description": "Real-time dashboard for monitoring multiple Claude Code sessions across SSH hosts",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "claude-code-monitor": "./server/index.js",
    "claude-code-monitor-agent": "./agent/index.js",
    "claude-code-monitor-mcp": "./server/mcp.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npx vite --port 3457",
    "build": "cd client && npx vite build",
    "start": "NODE_ENV=production node server/index.js",
    "share": "uv run share.py",
    "status": "bash scripts/quick-status.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.0",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "monitor",
    "dashboard",
    "ssh",
    "tmux",
    "developer-tools"
  ],
  "author": "Xiang Pan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xiang-Pan/claude-code-monitor.git"
  },
  "homepage": "https://github.com/Xiang-Pan/claude-code-monitor",
  "bugs": {
    "url": "https://github.com/Xiang-Pan/claude-code-monitor/issues"
  },
  "files": [
    "server/",
    "agent/",
    "client/dist/",
    "scripts/",
    "config.example.json",
    "hooks.example.json",
    "share.py",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
